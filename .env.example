# Core
DISCORD_TOKEN=
BOT_PREFIX=%
DISCORD_BOT_NAME=NEKO
DISCORD_BOT_ID=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# Spotify for Lavalink/LavaSrc (required for Spotify URLs in %play)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional proxy for bot-side Spotify web fallback (playlist/album/artist)
SPOTIFY_PROXY_URL=
SPOTIFY_PROXY_USERNAME=
SPOTIFY_PROXY_PASSWORD=
# Prefer anonymous Spotify token flow in LavaSrc (can cause 429 on some IPs)
SPOTIFY_PREFER_ANONYMOUS_TOKEN=false
# Optional custom anonymous token endpoint for LavaSrc Spotify
SPOTIFY_TOKEN_ENDPOINT=http://spotify-tokener:8080/api/token
# Optional market used by LavaSrc Spotify resolver (e.g. US, DE)
SPOTIFY_MARKET=US

# Yandex
YANDEX_TOKEN=
# Optional proxy for Yandex metadata resolution via LavaSrc only
YANDEX_PROXY_URL=
YANDEX_PROXY_USERNAME=
YANDEX_PROXY_PASSWORD=

# Lavalink / Wavelink
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
PLAYER_DEFAULT_VOLUME=100
